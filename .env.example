# Copy to .env in this directory (repo root), then fill in your key:
#   copy .env.example .env
#
# Run claw from the repo root so this file is picked up:
#   .\rust\target\debug\claw.exe doctor
#   .\rust\target\debug\claw.exe prompt "hello"
#
# Both OPENAI_API_KEY and OPENAI_BASE_URL are read from .env when not in shell env.
# Model name lives in .claw/settings.json (not here).

# --- OpenAI (official API) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Optional: OpenRouter (uncomment and comment OpenAI lines above) ---
# OPENAI_API_KEY=sk-or-v1-replace-me
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Optional: local Ollama (no key needed) ---
# OLLAMA_HOST=http://127.0.0.1:11434

# Remove or leave unset if you are not using Anthropic (avoids wrong routing):
# ANTHROPIC_API_KEY=
